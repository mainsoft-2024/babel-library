{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Easy CBOR Module Config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "max_recursion_depth": {
      "anyOf": [
        { "type": "integer", "minimum": 0 },
        { "type": "string", "minLength": 1 }
